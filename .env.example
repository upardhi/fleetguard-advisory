# ── Supabase Postgres (Mumbai, ap-south-1) ────────────────────────────────────
# Pooled connection via pgBouncer (port 6543) — used by runtime queries
SUPABASE_POOLER_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Direct connection (port 5432) — used only by npm run db:migrate
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres

# ── Vercel Blob ───────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── Auth ──────────────────────────────────────────────────────────────────────
# 64-character hex string — generate with: openssl rand -hex 64
JWT_SECRET=

# 64-character hex string (32 bytes → AES-256 key) — generate with: openssl rand -hex 32
# NOTE: this must be exactly 64 hex chars (32 bytes)
ENCRYPTION_MASTER_KEY=

# ── Cron ──────────────────────────────────────────────────────────────────────
# Arbitrary secret sent in Authorization: Bearer <CRON_SECRET> by Vercel Cron
CRON_SECRET=

# ── Firebase (legacy — kept until full Supabase migration is complete) ────────
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
FLEETGUARD_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Third-party integrations ──────────────────────────────────────────────────
QR_SECRET=
MSG91_AUTH_KEY=
SENDGRID_API_KEY=

# ── Insights / AI summary ─────────────────────────────────────────────────────
# Used by /api/v2/insights/summary to generate the executive narrative on the
# Manager + CSO Insights pages. When unset, the route falls back to a
# deterministic local summary so the UI still works.
OPENAI_API_KEY=

# ── ITC-LI attendance import ──────────────────────────────────────────────────
# Firestore orgId that belongs to ITC — used to filter verificationRequests
ITC_LI_ORG_ID=
# Fleetguard warehouse UUID to import ITC records into (used by the daily cron)
ITC_LI_WAREHOUSE_ID=
